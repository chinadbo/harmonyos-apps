{
  "app": {
    "signingConfigs": [],
    "compileSdkVersion": "5.0.0(12)",
    "compatibleSdkVersion": "5.0.0(12)",
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compileSdk": {
          "apiVersion": "16"
        },
        "compatibleSdk": {
          "apiVersion": "16"
        },
        "runtimeOS": "HarmonyOS"
      }
    ],
    "buildOption": {
      "strictMode": {
        "caseSensitiveCheck": true,
        "useNormalizedOHMUrl": true
      }
    }
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    }
  ]
}
