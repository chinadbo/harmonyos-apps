[
  {
    "id": 1,
    "title": "静夜思",
    "author": "李白",
    "dynasty": "唐",
    "genre": "五言绝句",
    "content": ["床前明月光，", "疑是地上霜。", "举头望明月，", "低头思故乡。"],
    "annotation": ["床前：一说指床边，也有作窗前之解。", "疑：好像。", "举头：抬头。"],
    "appreciation": "诗人借明月与秋霜般的夜色，写出漂泊异乡时突然而深切的思乡之情，语言平易却极具感染力。",
    "tags": ["思乡", "月夜", "经典"]
  },
  {
    "id": 2,
    "title": "春晓",
    "author": "孟浩然",
    "dynasty": "唐",
    "genre": "五言绝句",
    "content": ["春眠不觉晓，", "处处闻啼鸟。", "夜来风雨声，", "花落知多少。"],
    "annotation": ["晓：天明。", "闻：听见。", "知多少：不知道有多少。"],
    "appreciation": "通过春晨的听觉与回想中的风雨，表现春景的可爱与对落花的惜春之意，构思自然活泼。",
    "tags": ["春天", "惜花", "自然"]
  },
  {
    "id": 3,
    "title": "登鹳雀楼",
    "author": "王之涣",
    "dynasty": "唐",
    "genre": "五言绝句",
    "content": ["白日依山尽，", "黄河入海流。", "欲穷千里目，", "更上一层楼。"],
    "annotation": ["依：挨着。", "穷：尽，达到极点。", "更：再。"],
    "appreciation": "前两句写壮阔景象，后两句由景生理，启示人们只有站得更高，才能看得更远，意境开阔。",
    "tags": ["哲理", "登高", "边塞"]
  },
  {
    "id": 4,
    "title": "将进酒",
    "author": "李白",
    "dynasty": "唐",
    "genre": "乐府",
    "content": ["君不见，黄河之水天上来，奔流到海不复回。", "君不见，高堂明镜悲白发，朝如青丝暮成雪。", "人生得意须尽欢，莫使金樽空对月。", "天生我材必有用，千金散尽还复来。", "烹羊宰牛且为乐，会须一饮三百杯。", "岑夫子，丹丘生，将进酒，杯莫停。", "与君歌一曲，请君为我倾耳听。", "钟鼓馔玉不足贵，但愿长醉不愿醒。", "古来圣贤皆寂寞，惟有饮者留其名。", "陈王昔时宴平乐，斗酒十千恣欢谑。", "主人何为言少钱，径须沽取对君酌。", "五花马，千金裘，呼儿将出换美酒，与尔同销万古愁。"],
    "annotation": ["会须：应当，应该。", "钟鼓馔玉：富贵人家的华美生活。", "陈王：曹植。"],
    "appreciation": "全诗气势奔放，兼有及时行乐的豪情与怀才不遇的愤激，展现了李白浪漫主义诗风的典型特征。",
    "tags": ["豪放", "饮酒", "人生"]
  },
  {
    "id": 5,
    "title": "望庐山瀑布",
    "author": "李白",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["日照香炉生紫烟，", "遥看瀑布挂前川。", "飞流直下三千尺，", "疑是银河落九天。"],
    "annotation": ["香炉：香炉峰。", "前川：面前的河流。", "九天：天的极高处。"],
    "appreciation": "诗人以夸张和想象描绘瀑布的壮丽，将自然景观写得神奇瑰伟，体现浪漫想象力。",
    "tags": ["山水", "瀑布", "浪漫"]
  },
  {
    "id": 6,
    "title": "早发白帝城",
    "author": "李白",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["朝辞白帝彩云间，", "千里江陵一日还。", "两岸猿声啼不住，", "轻舟已过万重山。"],
    "annotation": ["白帝：白帝城。", "江陵：今湖北江陵。", "万重山：层层叠叠的群山。"],
    "appreciation": "诗中速度感极强，既写出舟行迅疾，也写出诗人获释后的轻快心情，情景交融。",
    "tags": ["行旅", "快意", "山水"]
  },
  {
    "id": 7,
    "title": "黄鹤楼",
    "author": "崔颢",
    "dynasty": "唐",
    "genre": "七言律诗",
    "content": ["昔人已乘黄鹤去，", "此地空余黄鹤楼。", "黄鹤一去不复返，", "白云千载空悠悠。", "晴川历历汉阳树，", "芳草萋萋鹦鹉洲。", "日暮乡关何处是，", "烟波江上使人愁。"],
    "annotation": ["晴川：晴日下的江面。", "历历：分明可数。", "乡关：故乡。"],
    "appreciation": "诗歌由传说起兴，写登楼所见与所感，最终落到日暮怀乡，意境苍茫而深沉。",
    "tags": ["登楼", "怀古", "思乡"]
  },
  {
    "id": 8,
    "title": "枫桥夜泊",
    "author": "张继",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["月落乌啼霜满天，", "江枫渔火对愁眠。", "姑苏城外寒山寺，", "夜半钟声到客船。"],
    "annotation": ["江枫：江边枫树。", "渔火：渔船上的灯火。", "姑苏：苏州旧称。"],
    "appreciation": "诗中夜色、钟声、愁绪相互映衬，画面清冷幽远，是羁旅诗中的名篇。",
    "tags": ["羁旅", "夜景", "愁绪"]
  },
  {
    "id": 9,
    "title": "送元二使安西",
    "author": "王维",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["渭城朝雨浥轻尘，", "客舍青青柳色新。", "劝君更尽一杯酒，", "西出阳关无故人。"],
    "annotation": ["浥：湿润。", "客舍：旅店。", "阳关：古关名，出关后多荒凉。"],
    "appreciation": "以清新的送别场景衬托深厚友情，末句尤为感人，含蓄写尽远行的孤独。",
    "tags": ["送别", "友情", "边塞"]
  },
  {
    "id": 10,
    "title": "九月九日忆山东兄弟",
    "author": "王维",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["独在异乡为异客，", "每逢佳节倍思亲。", "遥知兄弟登高处，", "遍插茱萸少一人。"],
    "annotation": ["山东：华山以东，非今山东省专指。", "登高：重阳节习俗。", "茱萸：重阳佩戴之物。"],
    "appreciation": "诗人抓住重阳佳节的民俗，引出异乡人的思亲之情，语言朴素而感情真挚。",
    "tags": ["重阳", "思亲", "节日"]
  },
  {
    "id": 11,
    "title": "相思",
    "author": "王维",
    "dynasty": "唐",
    "genre": "五言绝句",
    "content": ["红豆生南国，", "春来发几枝。", "愿君多采撷，", "此物最相思。"],
    "annotation": ["南国：南方。", "采撷：采摘。", "红豆：相思子。"],
    "appreciation": "借红豆寄托相思之情，含蓄优美，物象鲜明，具有民歌风味。",
    "tags": ["相思", "红豆", "友情"]
  },
  {
    "id": 12,
    "title": "出塞",
    "author": "王昌龄",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["秦时明月汉时关，", "万里长征人未还。", "但使龙城飞将在，", "不教胡马度阴山。"],
    "annotation": ["龙城飞将：指李广一类名将。", "胡马：敌方骑兵。", "阴山：山名，古代边防要地。"],
    "appreciation": "借历史与现实对照，表达对边防将领的期望，也含有对战争久拖不决的感慨。",
    "tags": ["边塞", "战争", "豪情"]
  },
  {
    "id": 13,
    "title": "凉州词",
    "author": "王之涣",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["黄河远上白云间，", "一片孤城万仞山。", "羌笛何须怨杨柳，", "春风不度玉门关。"],
    "annotation": ["万仞：极言山高。", "杨柳：折柳曲，常寄离情。", "玉门关：古西北边塞关隘。"],
    "appreciation": "边塞雄浑中带有苍凉，末句写出边地苦寒与戍边人的复杂心绪。",
    "tags": ["边塞", "苍凉", "戍边"]
  },
  {
    "id": 14,
    "title": "芙蓉楼送辛渐",
    "author": "王昌龄",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["寒雨连江夜入吴，", "平明送客楚山孤。", "洛阳亲友如相问，", "一片冰心在玉壶。"],
    "annotation": ["平明：天刚亮。", "楚山：泛指江南山水。", "冰心玉壶：比喻高洁清白。"],
    "appreciation": "诗人借送别表达自守清廉、高洁不移的品格，情感含蓄而坚定。",
    "tags": ["送别", "品格", "高洁"]
  },
  {
    "id": 15,
    "title": "咏鹅",
    "author": "骆宾王",
    "dynasty": "唐",
    "genre": "五言古诗",
    "content": ["鹅，鹅，鹅，", "曲项向天歌。", "白毛浮绿水，", "红掌拨清波。"],
    "annotation": ["曲项：弯曲的脖子。", "拨：划动。", "清波：清澈的水波。"],
    "appreciation": "短短数句抓住鹅的色彩、姿态与动作，生动活泼，富有儿童情趣。",
    "tags": ["童趣", "动物", "启蒙"]
  },
  {
    "id": 16,
    "title": "悯农",
    "author": "李绅",
    "dynasty": "唐",
    "genre": "五言绝句",
    "content": ["春种一粒粟，", "秋收万颗子。", "四海无闲田，", "农夫犹饿死。"],
    "annotation": ["粟：谷子。", "四海：天下。", "犹：还。"],
    "appreciation": "以强烈对比揭示封建社会中农民劳而无获的悲苦命运，具有深刻的社会意义。",
    "tags": ["民生", "农事", "讽喻"]
  },
  {
    "id": 17,
    "title": "锄禾",
    "author": "李绅",
    "dynasty": "唐",
    "genre": "五言绝句",
    "content": ["锄禾日当午，", "汗滴禾下土。", "谁知盘中餐，", "粒粒皆辛苦。"],
    "annotation": ["锄禾：给禾苗松土除草。", "盘中餐：碗盘中的饭食。", "皆：都。"],
    "appreciation": "通过劳作场景写出粮食来之不易，劝诫人们珍惜劳动成果，通俗而警策。",
    "tags": ["惜食", "农耕", "教育"]
  },
  {
    "id": 18,
    "title": "游子吟",
    "author": "孟郊",
    "dynasty": "唐",
    "genre": "乐府",
    "content": ["慈母手中线，", "游子身上衣。", "临行密密缝，", "意恐迟迟归。", "谁言寸草心，", "报得三春晖。"],
    "annotation": ["意恐：担心。", "寸草心：比喻子女微小的心意。", "三春晖：春天阳光，比喻母爱。"],
    "appreciation": "通过母亲缝衣的细节，写出深沉无私的母爱，末句以比兴收束，千古动人。",
    "tags": ["母爱", "亲情", "感恩"]
  },
  {
    "id": 19,
    "title": "清明",
    "author": "杜牧",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["清明时节雨纷纷，", "路上行人欲断魂。", "借问酒家何处有，", "牧童遥指杏花村。"],
    "annotation": ["断魂：形容哀伤深切。", "借问：请问。", "杏花村：酒店所在之地。"],
    "appreciation": "以清明微雨中的行旅人写节日氛围，哀愁与希望并存，画面感极强。",
    "tags": ["节日", "清明", "春雨"]
  },
  {
    "id": 20,
    "title": "江雪",
    "author": "柳宗元",
    "dynasty": "唐",
    "genre": "五言绝句",
    "content": ["千山鸟飞绝，", "万径人踪灭。", "孤舟蓑笠翁，", "独钓寒江雪。"],
    "annotation": ["绝：消失，没有。", "万径：无数道路。", "蓑笠翁：披蓑戴笠的老人。"],
    "appreciation": "极写天地之间的空寂与寒冷，在孤独的渔翁形象中寄托诗人不屈的精神。",
    "tags": ["孤高", "雪景", "山水"]
  },
  {
    "id": 21,
    "title": "渔歌子",
    "author": "张志和",
    "dynasty": "唐",
    "genre": "词",
    "content": ["西塞山前白鹭飞，", "桃花流水鳜鱼肥。", "青箬笠，绿蓑衣，", "斜风细雨不须归。"],
    "annotation": ["西塞山：地名。", "鳜鱼：一种淡水鱼。", "箬笠：竹叶编的斗笠。"],
    "appreciation": "词中渔父形象闲适自在，山水明丽，表现了超脱世俗的生活情趣。",
    "tags": ["词", "山水", "闲适"]
  },
  {
    "id": 22,
    "title": "望天门山",
    "author": "李白",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["天门中断楚江开，", "碧水东流至此回。", "两岸青山相对出，", "孤帆一片日边来。"],
    "annotation": ["天门山：安徽当涂西南二山隔江对峙。", "楚江：长江流经古楚地的一段。", "回：回旋。"],
    "appreciation": "写山势、水势与行舟动态，景象雄奇开阔，充满动态美。",
    "tags": ["山水", "长江", "壮阔"]
  },
  {
    "id": 23,
    "title": "绝句",
    "author": "杜甫",
    "dynasty": "唐",
    "genre": "七言绝句",
    "content": ["两个黄鹂鸣翠柳，", "一行白鹭上青天。", "窗含西岭千秋雪，", "门泊东吴万里船。"],
    "annotation": ["西岭：西边的山岭。", "千秋雪：终年不化的积雪。", "东吴：今江浙一带。"],
    "appreciation": "色彩绚丽、画面开阔，近景远景交织，表现了春日草堂的生机与诗人心境的舒展。",
    "tags": ["春景", "色彩", "写景"]
  },
  {
    "id": 24,
    "title": "春日",
    "author": "朱熹",
    "dynasty": "宋",
    "genre": "七言绝句",
    "content": ["胜日寻芳泗水滨，", "无边光景一时新。", "等闲识得东风面，", "万紫千红总是春。"],
    "annotation": ["胜日：天气晴朗的好日子。", "寻芳：游春赏花。", "等闲：轻易。"],
    "appreciation": "通过寻春、识春写出春光明媚与理趣之美，末句尤见开朗境界。",
    "tags": ["春天", "理趣", "宋诗"]
  },
  {
    "id": 25,
    "title": "题西林壁",
    "author": "苏轼",
    "dynasty": "宋",
    "genre": "七言绝句",
    "content": ["横看成岭侧成峰，", "远近高低各不同。", "不识庐山真面目，", "只缘身在此山中。"],
    "annotation": ["西林：西林寺。", "缘：因为。", "真面目：真实全貌。"],
    "appreciation": "由观山生发哲理，说明认识事物常受立场与角度限制，寓理于景，警策深刻。",
    "tags": ["哲理", "庐山", "苏轼"]
  },
  {
    "id": 26,
    "title": "饮湖上初晴后雨",
    "author": "苏轼",
    "dynasty": "宋",
    "genre": "七言绝句",
    "content": ["水光潋滟晴方好，", "山色空蒙雨亦奇。", "欲把西湖比西子，", "淡妆浓抹总相宜。"],
    "annotation": ["潋滟：波光闪动。", "空蒙：迷茫缥缈。", "西子：西施。"],
    "appreciation": "以西子喻西湖，写出晴雨皆美的风姿，既有视觉美感又有审美妙趣。",
    "tags": ["西湖", "写景", "比喻"]
  },
  {
    "id": 27,
    "title": "晓出净慈寺送林子方",
    "author": "杨万里",
    "dynasty": "宋",
    "genre": "七言绝句",
    "content": ["毕竟西湖六月中，", "风光不与四时同。", "接天莲叶无穷碧，", "映日荷花别样红。"],
    "annotation": ["毕竟：到底。", "四时：四季。", "别样：格外。"],
    "appreciation": "诗人抓住盛夏西湖最鲜明的荷景，色彩浓烈，气象开阔，极富感染力。",
    "tags": ["西湖", "荷花", "夏天"]
  },
  {
    "id": 28,
    "title": "泊船瓜洲",
    "author": "王安石",
    "dynasty": "宋",
    "genre": "七言绝句",
    "content": ["京口瓜洲一水间，", "钟山只隔数重山。", "春风又绿江南岸，", "明月何时照我还。"],
    "annotation": ["京口：今江苏镇江。", "瓜洲：今扬州南运河入江处。", "绿：吹绿。"],
    "appreciation": "借江南春色抒写思归之情，一个“绿”字尤见炼字之功，脍炙人口。",
    "tags": ["思归", "江南", "炼字"]
  },
  {
    "id": 29,
    "title": "元日",
    "author": "王安石",
    "dynasty": "宋",
    "genre": "七言绝句",
    "content": ["爆竹声中一岁除，", "春风送暖入屠苏。", "千门万户曈曈日，", "总把新桃换旧符。"],
    "annotation": ["屠苏：古代节日饮用的酒。", "曈曈：太阳初升明亮貌。", "桃符：春联前身。"],
    "appreciation": "诗中洋溢着新春更新的欢乐气氛，也寄寓变法图新的政治理想。",
    "tags": ["春节", "节日", "喜庆"]
  },
  {
    "id": 30,
    "title": "梅花",
    "author": "王安石",
    "dynasty": "宋",
    "genre": "五言绝句",
    "content": ["墙角数枝梅，", "凌寒独自开。", "遥知不是雪，", "为有暗香来。"],
    "annotation": ["凌寒：冒着严寒。", "遥知：远远地知道。", "暗香：幽微的香气。"],
    "appreciation": "借梅花不畏严寒、幽香自守的形象，赞美高洁坚贞的品格，含蓄耐品。",
    "tags": ["梅花", "品格", "咏物"]
  }
]
